<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FC"
    tools:context=".pages.profile.AdminConsoleFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnAdminBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_home_circle_white"
                    android:contentDescription="Quay lại"
                    android:padding="10dp"
                    android:src="@drawable/ic_back"
                    app:tint="@color/text_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Bảng quản trị"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAdminConsoleRole"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_admin_console_badge"
                    android:gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:text="Admin"
                    android:textColor="@color/primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutAdminLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_loading_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:indeterminate="true"
                    android:indeterminateTint="@color/primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Đang tải dữ liệu quản trị..."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVerificationQueue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="22dp"
                app:cardElevation="3dp"
                app:strokeColor="#E6ECF5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Duyệt xác thực sinh viên"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvVerificationQueueSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Đang tải danh sách yêu cầu..."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvVerificationQueue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_admin_verification" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAdminStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="22dp"
                app:cardElevation="3dp"
                app:strokeColor="#E6ECF5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="4">

                        <LinearLayout
                            style="@style/AdminStatTile"
                            android:layout_columnWeight="1">

                            <TextView
                                android:id="@+id/tvAdminUsersTotal"
                                style="@style/AdminStatValue"
                                android:text="0" />

                            <TextView
                                style="@style/AdminStatLabel"
                                android:text="Người dùng" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/AdminStatTile"
                            android:layout_columnWeight="1">

                            <TextView
                                android:id="@+id/tvAdminVerifiedTotal"
                                style="@style/AdminStatValue"
                                android:text="0" />

                            <TextView
                                style="@style/AdminStatLabel"
                                android:text="Đã xác thực" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/AdminStatTile"
                            android:layout_columnWeight="1">

                            <TextView
                                android:id="@+id/tvAdminSuspendedTotal"
                                style="@style/AdminStatValue"
                                android:text="0" />

                            <TextView
                                style="@style/AdminStatLabel"
                                android:text="Đang bị khóa" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/AdminStatTile"
                            android:layout_columnWeight="1">

                            <TextView
                                android:id="@+id/tvAdminProductsTotal"
                                style="@style/AdminStatValue"
                                android:text="0" />

                            <TextView
                                style="@style/AdminStatLabel"
                                android:text="Tin đăng" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/AdminStatTile"
                            android:layout_columnWeight="1">

                            <TextView
                                android:id="@+id/tvAdminRemovedTotal"
                                style="@style/AdminStatValue"
                                android:text="0" />

                            <TextView
                                style="@style/AdminStatLabel"
                                android:text="Tin đã gỡ" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/AdminStatTile"
                            android:layout_columnWeight="1">

                            <TextView
                                android:id="@+id/tvAdminOrdersTotal"
                                style="@style/AdminStatValue"
                                android:text="0" />

                            <TextView
                                style="@style/AdminStatLabel"
                                android:text="Đơn hàng" />
                        </LinearLayout>

                        <LinearLayout
                            style="@style/AdminStatTileWide"
                            android:layout_columnSpan="2">

                            <TextView
                                android:id="@+id/tvAdminRevenueTotal"
                                style="@style/AdminStatValue"
                                android:text="0đ" />

                            <TextView
                                style="@style/AdminStatLabel"
                                android:text="Tổng giao dịch hoàn thành" />
                        </LinearLayout>
                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAdminUsers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="22dp"
                app:cardElevation="3dp"
                app:strokeColor="#E6ECF5"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Quản trị người dùng"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Khóa hoặc mở khóa tài khoản khi cần kiểm soát hoạt động."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />

                    <EditText
                        android:id="@+id/etAdminUserSearch"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_search_input"
                        android:hint="Tìm người dùng..."
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:singleLine="true"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="13sp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvAdminUsers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:nestedScrollingEnabled="false"
                        tools:listitem="@layout/item_admin_user" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
