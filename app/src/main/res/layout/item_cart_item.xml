<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_detail_white_card"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="12dp">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/ivCartProduct"
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="#EAF0FF"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_category_bag_24"
        app:shapeAppearanceOverlay="@style/RoundedImage" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvCartProductTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Tên sản phẩm"
            android:textColor="#101828"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCartProductPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="0đ"
            android:textColor="#0A2A7A"
            android:textSize="14sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnCartMinus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_quantity_button"
                android:gravity="center"
                android:text="-"
                android:textColor="#21409A"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCartQuantity"
                android:layout_width="38dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="1"
                android:textColor="#101828"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnCartPlus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_quantity_button"
                android:gravity="center"
                android:text="+"
                android:textColor="#21409A"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/btnCartRemove"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/bg_detail_close_button"
        android:gravity="center"
        android:text="×"
        android:textColor="#667085"
        android:textSize="24sp" />
</LinearLayout>
