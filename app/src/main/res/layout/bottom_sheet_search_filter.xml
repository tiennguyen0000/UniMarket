<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_filter_sheet"
    android:orientation="vertical">

    <View
        android:layout_width="48dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_filter_handle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="22dp"
        android:paddingTop="18dp"
        android:paddingEnd="22dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="Bộ lọc tìm kiếm"
                android:textColor="#101828"
                android:textSize="21sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvFilterSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Tinh chỉnh kết quả theo nhu cầu của bạn"
                android:textColor="#667085"
                android:textSize="13sp" />
        </LinearLayout>

        <ImageView
            android:id="@+id/closeButton"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_filter_close_button"
            android:contentDescription="Đóng bộ lọc"
            android:padding="11dp"
            android:scaleType="centerInside"
            android:src="@drawable/close"
            app:tint="#667085" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:maxHeight="520dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_filter_section_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="Khoảng giá"
                    android:textColor="#101828"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Nhập theo VND, có thể bỏ trống một phía."
                    android:textColor="#667085"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Từ"
                            android:textColor="#667085"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etPriceFrom"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="7dp"
                            android:background="@drawable/bg_filter_input"
                            android:hint="0đ"
                            android:inputType="numberDecimal"
                            android:maxLength="12"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:singleLine="true"
                            android:textColor="#101828"
                            android:textColorHint="#98A2B3"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="30dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="23dp"
                        android:gravity="center"
                        android:text="-"
                        android:textColor="#98A2B3"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Đến"
                            android:textColor="#667085"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <EditText
                            android:id="@+id/etPriceTo"
                            android:layout_width="match_parent"
                            android:layout_height="50dp"
                            android:layout_marginTop="7dp"
                            android:background="@drawable/bg_filter_input"
                            android:hint="Không giới hạn"
                            android:inputType="numberDecimal"
                            android:maxLength="12"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:singleLine="true"
                            android:textColor="#101828"
                            android:textColorHint="#98A2B3"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_filter_section_card"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="Tình trạng sản phẩm"
                    android:textColor="#101828"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cbNew"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_filter_chip_selector"
                        android:button="@null"
                        android:gravity="center"
                        android:minHeight="0dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="Hàng mới"
                        android:textColor="@color/filter_chip_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <CheckBox
                        android:id="@+id/cbUsed"
                        android:layout_width="0dp"
                        android:layout_height="54dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_filter_chip_selector"
                        android:button="@null"
                        android:gravity="center"
                        android:minHeight="0dp"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:text="Đã sử dụng"
                        android:textColor="@color/filter_chip_text"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E4EBF5" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp">

        <TextView
            android:id="@+id/btnResetFilter"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_filter_reset_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Đặt lại"
            android:textColor="#21409A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnApplyFilter"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_filter_primary_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="Áp dụng"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
