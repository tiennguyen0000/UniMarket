<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Sửa thông tin nhận hàng trước khi đơn bắt đầu giao."
        android:textColor="#667085"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_cart_field_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_cart_field_icon"
            android:padding="5dp"
            android:src="@drawable/phone1"
            app:tint="#21409A" />

        <EditText
            android:id="@+id/etOrderUpdatePhone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Số điện thoại"
            android:inputType="phone"
            android:singleLine="true"
            android:textColor="#101828"
            android:textColorHint="#98A2B3"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_cart_field_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_cart_field_icon"
            android:padding="5dp"
            android:src="@drawable/location"
            app:tint="#21409A" />

        <EditText
            android:id="@+id/etOrderUpdateLocation"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Vị trí nhận hàng"
            android:inputType="textPostalAddress"
            android:singleLine="true"
            android:textColor="#101828"
            android:textColorHint="#98A2B3"
            android:textSize="14sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_cart_shipping_option"
        android:orientation="vertical"
        android:paddingStart="12dp"
        android:paddingTop="4dp"
        android:paddingEnd="12dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:id="@+id/btnOrderUpdateStandard"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivOrderUpdateStandardIcon"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@android:color/transparent"
                android:padding="6dp"
                android:src="@drawable/shipping"
                app:tint="#21409A" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvOrderUpdateStandardTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Giao thường"
                    android:textColor="#21409A"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvOrderUpdateStandardDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Nhận trong 2-3 ngày"
                    android:textColor="#21409A"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvOrderUpdateStandardFee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="10.000đ"
                android:textColor="#21409A"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="46dp"
            android:layout_marginEnd="8dp"
            android:background="#E4EBF5" />

        <LinearLayout
            android:id="@+id/btnOrderUpdateExpress"
            android:layout_width="match_parent"
            android:layout_height="68dp"
            android:background="@android:color/transparent"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/ivOrderUpdateExpressIcon"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@android:color/transparent"
                android:padding="6dp"
                android:src="@drawable/rocket"
                app:tint="#667085" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvOrderUpdateExpressTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hỏa tốc"
                    android:textColor="#667085"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvOrderUpdateExpressDetail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:text="Nhận trong 24 giờ"
                    android:textColor="#667085"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvOrderUpdateExpressFee"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="25.000đ"
                android:textColor="#667085"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_cart_field_row"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_cart_field_icon"
            android:padding="5dp"
            android:src="@drawable/remind"
            app:tint="#21409A" />

        <EditText
            android:id="@+id/etOrderUpdateNote"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Lời nhắc cho người bán"
            android:inputType="text"
            android:singleLine="true"
            android:textColor="#101828"
            android:textColorHint="#98A2B3"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
