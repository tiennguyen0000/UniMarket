<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="282dp"
    android:background="@drawable/bg_item_product_card"
    android:clickable="true"
    android:elevation="3dp"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="10dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:background="@drawable/bg_item_product_media">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProductImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Ảnh sản phẩm"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/RoundedImage" />

        <ImageView
            android:id="@+id/ivProductFallbackIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:contentDescription="Biểu tượng danh mục"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_category_bag_24"
            app:tint="#21409A" />

        <TextView
            android:id="@+id/tvProductFavorite"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:background="@drawable/bg_item_product_favorite"
            android:elevation="4dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="♡"
            android:textColor="#98A2B3"
            android:textSize="19sp" />

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivSellerAvatar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="bottom|start"
            android:layout_margin="8dp"
            android:background="@color/white"
            android:padding="1.5dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_user_placeholder"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/white"
            app:strokeWidth="1dp" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvProductCategory"
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:gravity="bottom"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="DANH MỤC"
        android:textColor="#7C8798"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvProductName"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:includeFontPadding="false"
        android:lineSpacingExtra="1dp"
        android:maxLines="2"
        android:text="Tên sản phẩm"
        android:textColor="#111827"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvProductMeta"
        android:layout_width="wrap_content"
        android:layout_height="22dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_item_product_meta"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:text="Tình trạng"
        android:textColor="#21409A"
        android:textSize="10sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvProductPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:text="0đ"
            android:textColor="#0A2A7A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAddProduct"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_item_product_add_button"
            android:elevation="3dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="25sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>