<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_item_product_card"
    android:orientation="vertical"
    android:padding="10dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="118dp"
        android:background="@drawable/bg_item_product_media">

        <ImageView
            android:id="@+id/ivProductImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Product image"
            android:scaleType="centerCrop" />

        <ImageView
            android:id="@+id/ivProductFallbackIcon"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center"
            android:contentDescription="Category icon"
            android:scaleType="fitCenter"
            android:src="@drawable/laptop" />

        <TextView
            android:id="@+id/tvProductFavorite"
            android:layout_width="34dp"
            android:layout_height="34dp"
            android:layout_gravity="top|end"
            android:layout_margin="8dp"
            android:background="@drawable/bg_item_product_favorite"
            android:gravity="center"
            android:text="♡"
            android:textColor="#B8BFCC"
            android:textSize="19sp" />

        <!-- Seller Avatar -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivSellerAvatar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="bottom|start"
            android:layout_margin="8dp"
            android:padding="1.5dp"
            android:background="@color/white"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/CircleImage"
            android:src="@drawable/ic_user_placeholder"
            app:strokeColor="@color/white"
            app:strokeWidth="1dp" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvProductCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="DANH MUC"
        android:textColor="#98A1B2"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvProductName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:maxLines="2"
        android:text="Ten san pham"
        android:textColor="#101828"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvProductMeta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_item_product_meta"
        android:paddingStart="7dp"
        android:paddingTop="3dp"
        android:paddingEnd="7dp"
        android:paddingBottom="3dp"
        android:text="Tinh trang"
        android:textColor="#21409A"
        android:textSize="11sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="9dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvProductPrice"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0d"
            android:textColor="#0A2A7A"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAddProduct"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_item_product_add_button"
            android:gravity="center"
            android:text="+"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>