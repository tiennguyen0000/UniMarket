<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="#F5F7FA"
    tools:context=".HomeActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="UniMarket"
            android:textColor="#1E293B"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bảng điều khiển dành cho sinh viên"
            android:textColor="#64748B"
            android:textSize="14sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Tính năng ứng dụng"
            android:textColor="#334155"
            android:textSize="16sp"
            android:textStyle="bold" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <Button
                android:id="@+id/btnProducts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:padding="16dp"
                android:text="📦 Sản phẩm"
                android:backgroundTint="#0EA5E9"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnCart"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:padding="16dp"
                android:text="🛒 Giỏ hàng"
                android:backgroundTint="#10B981"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnOrders"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:padding="16dp"
                android:text="📋 Đơn hàng"
                android:backgroundTint="#F59E0B"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnChat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp"
                android:padding="16dp"
                android:text="💬 Tin nhắn"
                android:backgroundTint="#8B5CF6"
                android:textColor="#FFFFFF" />
        </GridLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="24dp"
            android:background="#E2E8F0" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Developer Tools 🛠️"
            android:textColor="#64748B"
            android:textSize="14sp"
            android:textStyle="bold|italic" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:text="Khu vực dành riêng cho nhóm phát triển để test hệ thống."
            android:textColor="#94A3B8"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btnOpenCrudTest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="4dp"
            android:padding="14dp"
            android:text="MỞ HỆ THỐNG TEST CRUD (REFLECTION)"
            android:backgroundTint="#475569"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>