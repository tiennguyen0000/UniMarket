<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/controllerNavHost"
        android:name="androidx.navigation.fragment.NavHostFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:defaultNavHost="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNavCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:navGraph="@navigation/main_nav_graph" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavCard"
        android:layout_width="0dp"
        android:layout_height="70dp"
        android:layout_marginStart="0dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp"
        android:stateListAnimator="@null"
        android:elevation="16dp"
        app:cardBackgroundColor="@android:color/white"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:strokeColor="@android:color/transparent"
        app:strokeWidth="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/white"
            android:orientation="horizontal"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <LinearLayout
                android:id="@+id/tabHome"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ivTabHome"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Trang chủ"
                    android:src="@drawable/home"
                    app:tint="#21409A" />

                <TextView
                    android:id="@+id/tvTabHome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Trang chủ"
                    android:textColor="#21409A"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ivTabSearch"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Tìm kiếm"
                    android:src="@drawable/search"
                    app:tint="#9CA3AF" />

                <TextView
                    android:id="@+id/tvTabSearch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Tìm kiếm"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <Space
                android:layout_width="60dp"
                android:layout_height="match_parent" />

            <LinearLayout
                android:id="@+id/tabOrders"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ivTabOrders"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Đơn hàng"
                    android:src="@drawable/order"
                    app:tint="#9CA3AF" />

                <TextView
                    android:id="@+id/tvTabOrders"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Đơn hàng"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/tabProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ivTabProfile"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Hồ sơ"
                    android:src="@drawable/profile"
                    app:tint="#9CA3AF" />

                <TextView
                    android:id="@+id/tvTabProfile"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Hồ sơ"
                    android:textColor="#9CA3AF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <ImageView
        android:id="@+id/imageViewMenu"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_home_sell_button"
        android:clickable="true"
        android:contentDescription="Đăng bán"
        android:elevation="18dp"
        android:focusable="true"
        android:padding="14dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_add_24"
        app:tint="@android:color/white"
        android:translationY="28dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavCard"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
