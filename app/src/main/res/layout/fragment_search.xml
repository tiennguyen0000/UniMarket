<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7FC"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".pages.search.SearchFragment">

    <FrameLayout
        android:id="@+id/searchAppBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#DDF4F7FC"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:elevation="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingStart="14dp"
            android:paddingTop="8dp"
            android:paddingEnd="14dp"
            android:paddingBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="top"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/layoutSearchSurface"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_search_history_dropdown"
                    android:elevation="4dp"
                    android:minHeight="48dp"
                    android:orientation="vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="7dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/etSearchQuery"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:hint="Tìm kiếm sản phẩm..."
                            android:imeOptions="actionSearch"
                            android:paddingStart="0dp"
                            android:paddingEnd="0dp"
                            android:singleLine="true"
                            android:textColor="#101828"
                            android:textColorHint="#9CA3AF"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/btnFilter"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:background="@android:color/transparent"
                            android:contentDescription="Bộ lọc"
                            android:padding="10dp"
                            android:scaleType="centerInside"
                            android:src="@drawable/tune"
                            app:tint="#667085" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutSearchHistoryDropdown"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingTop="2dp"
                        android:paddingBottom="12dp"
                        android:visibility="gone">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="10dp"
                            android:background="#E6ECF5" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Tìm kiếm gần đây"
                                android:textColor="#101828"
                                android:textSize="13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/btnClearSearchHistory"
                                android:layout_width="wrap_content"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_sort_chip"
                                android:gravity="center"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp"
                                android:text="Xóa"
                                android:textColor="#21409A"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/layoutSearchHistoryList"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />
                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:id="@+id/btnSearchCart"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="12dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Giỏ hàng"
                    android:padding="9dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_cart_24"
                    app:tint="#111827" />

                <ImageView
                    android:id="@+id/btnSearchChat"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_marginStart="2dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="Tin nhắn"
                    android:padding="10dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_chat_24"
                    app:tint="#111827" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/searchScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingTop="76dp"
        android:paddingBottom="150dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical"
            android:paddingStart="2dp"
            android:paddingTop="6dp"
            android:paddingEnd="2dp"
            android:paddingBottom="34dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tvSearchResults"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Kết quả tìm kiếm"
                    android:textColor="#101828"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvResultCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="(0)"
                    android:textColor="#6B7280"
                    android:textSize="14sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/sortRelevance"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginEnd="10dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Phù hợp nhất"
                        android:textColor="#21409A"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/sortNewest"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginEnd="10dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Mới nhất"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/sortPriceLow"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginEnd="10dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Giá thấp"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/sortPriceHigh"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginEnd="10dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Giá cao"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/sortRating"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginEnd="10dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Đánh giá cao"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/sortSaved"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:layout_marginEnd="10dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Tin đã lưu"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />
                    <TextView
                        android:id="@+id/sortMine"
                        android:layout_width="wrap_content"
                        android:layout_height="56dp"
                        android:background="@android:color/transparent"
                        android:gravity="center"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:text="Tin của tôi"
                        android:textColor="#6B7280"
                        android:textSize="13sp" />
                </LinearLayout>
            </HorizontalScrollView>

            <LinearLayout
                android:id="@+id/layoutSearchLoading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_loading_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="26dp"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:indeterminate="true"
                    android:indeterminateTint="#21409A" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Đang tải sản phẩm phù hợp..."
                    android:textColor="#667085"
                    android:textSize="13sp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSearchProducts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_product" />

            <TextView
                android:id="@+id/btnShowMoreProducts"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="4dp"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:text="Hiển thị thêm"
                android:textColor="#6B7280"
                android:textSize="14sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/layoutSearchEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_loading_card"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="28dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_home_action_icon"
                    android:gravity="center"
                    android:text="?"
                    android:textColor="#21409A"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSearchEmptyTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center"
                    android:text="Chưa tìm thấy sản phẩm"
                    android:textColor="#101828"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSearchEmptyMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp"
                    android:text="Thử đổi từ khóa, bỏ bớt bộ lọc hoặc xem lại sau."
                    android:textColor="#667085"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
