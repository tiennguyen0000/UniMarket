<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_detail_surface"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="18dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Cập nhật đơn hàng"
            android:textColor="#101828"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnOrderUpdateClose"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_detail_close_button"
            android:gravity="center"
            android:text="×"
            android:textColor="#667085"
            android:textSize="24sp" />
    </LinearLayout>

    <include layout="@layout/dialog_order_update" />

    <TextView
        android:id="@+id/btnOrderUpdateSave"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_detail_primary_button"
        android:gravity="center"
        android:text="Lưu thay đổi"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold" />
</LinearLayout>
