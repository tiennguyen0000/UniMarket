<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AdminStatTile">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">76dp</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:background">@drawable/bg_admin_stat_tile</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
    </style>

    <style name="AdminStatTileWide" parent="AdminStatTile">
        <item name="android:layout_width">match_parent</item>
    </style>

    <style name="AdminStatValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="AdminStatLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
    </style>
</resources>
