<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Unimarket" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:colorAccent">@color/primary</item>
        <item name="android:windowBackground">#F4F7FC</item>
        <item name="android:statusBarColor">@color/white</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="android:forceDarkAllowed" tools:targetApi="q">false</item>
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorSurfaceVariant">@color/white</item>
        <item name="colorSurfaceContainer">@color/white</item>
        <item name="colorSurfaceContainerLow">@color/white</item>
        <item name="colorSurfaceContainerHigh">@color/white</item>
        <item name="android:colorBackground">#F4F7FC</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="materialCardViewStyle">@style/Widget.UniMarket.MaterialCardView</item>
    </style>

    <style name="Theme.Unimarket" parent="Base.Theme.Unimarket" />

    <style name="CircleImage" parent="">
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedImage" parent="">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.UniMarket.MaterialCardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="strokeColor">#EAECF0</item>
    </style>

    <style name="ThemeOverlay.UniMarket.OrderPopupMenu" parent="ThemeOverlay.Material3.Light">
        <item name="popupMenuStyle">@style/Widget.UniMarket.OrderPopupMenu</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
    </style>

    <style name="Widget.UniMarket.OrderPopupMenu" parent="Widget.AppCompat.PopupMenu.Overflow">
        <item name="android:popupBackground">@drawable/bg_order_popup_menu</item>
        <item name="android:dropDownHorizontalOffset">-8dp</item>
        <item name="android:dropDownVerticalOffset">6dp</item>
        <item name="textAppearanceLargePopupMenu">@style/TextAppearance.UniMarket.OrderPopupMenu</item>
        <item name="textAppearanceSmallPopupMenu">@style/TextAppearance.UniMarket.OrderPopupMenu</item>
        <item name="overlapAnchor">false</item>
    </style>

    <style name="TextAppearance.UniMarket.OrderPopupMenu" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

</resources>
